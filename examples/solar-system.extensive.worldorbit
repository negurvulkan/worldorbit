schema 3.0

system Solar-System
  title "Solar System"
  description "Extensive atlas-style model of the Sun, planets, major moon systems, key minor bodies, large belts, heliophysical regions, and important artificial objects."
  epoch "AD-2026.0"
  referencePlane ecliptic

defaults
  view orthographic
  scale presentation
  preset atlas-card
  theme atlas

group inner-system
  label "Inner System"
  summary "Sun, terrestrial planets, and near-Sun structures"
  color #d7a25b

group asteroid-belt
  label "Asteroid Belt"
  summary "Main belt populations and dwarf-planet Ceres"
  color #b89168

group giant-systems
  label "Giant Planet Systems"
  summary "Jovian, Saturnian, Uranian, and Neptunian systems"
  color #7aa6c2

group kuiper-region
  label "Kuiper Region"
  summary "Kuiper belt, scattered disk bodies, and distant dwarf planets"
  color #7d88c8

group artificial
  label "Artificial Objects"
  summary "Stations, observatories, probes, and surface missions"
  color #c85b5b

group deep-space
  label "Deep Space"
  summary "Heliophysical boundaries and outbound probes"
  color #6a90b8

viewpoint overview
  label "System Overview"
  projection orthographic
  focus Sun
  select Sun
  camera
    azimuth 26
    elevation 20

viewpoint inner
  label "Inner System"
  projection perspective
  focus Earth
  select Earth
  camera
    azimuth 42
    elevation 24
    distance 8
  filter
    groups inner-system artificial

viewpoint outer
  label "Outer System"
  projection perspective
  focus Jupiter
  select Saturn
  camera
    azimuth 30
    elevation 22
    distance 11
  filter
    groups giant-systems kuiper-region

object star Sun
  mass 1sol
  radius 1sol
  temperature 5778K
  color #ffcc66
  groups inner-system
  info
    summary "Central star of the Solar System."
    spectralType "G2V main-sequence star"

