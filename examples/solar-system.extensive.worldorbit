trajectory voyager-1-grand-tour
  label "Voyager 1 Grand Tour"
  craft Voyager-1
  summary "Declarative reconstruction of the Jupiter-Saturn assist chain and outbound heliopause crossing."
  tags voyager gravity-assist interstellar
  color #b8c5d4

  segment earth-departure
    kind departure
    from Earth
    to Jupiter
    duration 546d
    deltaV 16.6km
    notes launch transfer-window

  segment jupiter-flyby
    kind flyby
    from Jupiter
    to Saturn
    assist Jupiter
    periapsis 349000km
    turnAngle 160deg
    duration 625d
    notes gravity-assist ring-plane-imaging
    maneuver titan-targeting
      kind targeting-burn
      deltaV 0.18km
      duration 22min
      notes saturn-encounter-setup

  segment saturn-flyby
    kind flyby
    from Saturn
    to Heliopause
    assist Saturn
    periapsis 124000km
    turnAngle 35deg
    duration 16000d
    notes heliosphere-exit titan-assisted-escape

